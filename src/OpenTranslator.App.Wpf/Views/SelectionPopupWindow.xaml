<Window x:Class="OpenTranslator.App.Wpf.Views.SelectionPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OpenTranslator.App.Wpf.Views"
        mc:Ignorable="d"
        Title="翻译结果" Height="380" Width="420"
        WindowStyle="None"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        BorderBrush="#E0E0E3"
        BorderThickness="1"
        Background="White">
    <Window.Resources>
        <SolidColorBrush x:Key="AccentColor" Color="#0F6BFF"/>
        <SolidColorBrush x:Key="BorderColor" Color="#E0E0E3"/>
        <SolidColorBrush x:Key="PanelBackground" Color="White"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#6B6B6F"/>
        <SolidColorBrush x:Key="SourceBg" Color="#F7F7F8"/>

        <Style x:Key="PopupComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Padding" Value="6,4"/>
                        <Setter Property="FontSize" Value="12"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <DockPanel Grid.Row="0" Margin="12,10,12,6" LastChildFill="False">
                <TextBlock Text="划词翻译" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                <Button Content="✕" 
                        DockPanel.Dock="Right"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        FontSize="14"
                        Foreground="{StaticResource TextSecondary}"
                        Padding="6,2"
                        Click="CloseButton_Click"/>
            </DockPanel>

            <!-- 语言选择栏 -->
            <Grid Grid.Row="1" Margin="12,2,12,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="SourceLangComboBox"
                          Grid.Column="0"
                          Style="{StaticResource PopupComboBox}"
                          HorizontalAlignment="Left"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Code"
                          SelectionChanged="SourceLangComboBox_SelectionChanged"/>
                <TextBlock Grid.Column="1" Text="→" Foreground="{StaticResource TextSecondary}" FontSize="12" VerticalAlignment="Center" Margin="8,0"/>
                <ComboBox x:Name="TargetLangComboBox"
                          Grid.Column="2"
                          Style="{StaticResource PopupComboBox}"
                          HorizontalAlignment="Right"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Code"
                          SelectionChanged="TargetLangComboBox_SelectionChanged"/>
            </Grid>

            <!-- 源文 -->
            <Grid Grid.Row="2" Background="{StaticResource SourceBg}" Margin="12,4,12,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="原文" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="10,6,10,2"/>
                <TextBox Grid.Row="1"
                         x:Name="SourceTextBlock"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="10,0,10,8"
                         FontSize="13"
                         Foreground="{StaticResource TextPrimary}"
                         TextWrapping="Wrap"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"/>
            </Grid>

            <!-- 分隔线 -->
            <Grid Grid.Row="3" Height="1" Background="{StaticResource BorderColor}" Margin="12,0,12,0"/>

            <!-- 译文 -->
            <Grid Grid.Row="4" Margin="12,4,12,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="译文" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="10,6,10,2"/>
                <TextBox Grid.Row="1"
                         x:Name="ResultTextBlock"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="10,0,10,8"
                         FontSize="13"
                         Foreground="{StaticResource TextPrimary}"
                         TextWrapping="Wrap"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"/>
            </Grid>

            <!-- 底部状态栏 -->
            <DockPanel Grid.Row="5" Margin="12,4,12,10" LastChildFill="False">
                <TextBlock x:Name="TimeTextBlock" FontSize="11" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                <Border DockPanel.Dock="Right">
                    <Button x:Name="CopyButton"
                            Background="{StaticResource AccentColor}"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="12"
                            Padding="14,5"
                            Click="CopyButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        复制
                    </Button>
                </Border>
            </DockPanel>
    </Grid>
</Window>
